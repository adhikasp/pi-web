{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/cli.ts",
    "src/plugin-api.ts",
    "src/plugin-api/unstable.ts",
    "extensions/pi-web.ts",
    "pi-web-plugins/**/pi-web-plugin.ts",
    "scripts/*.mjs",
    "packages/*/src/index.ts",
    "packages/*/src/cli.ts"
  ],
  "project": [
    "src/**/*.ts",
    "extensions/**/*.ts",
    "pi-web-plugins/**/*.ts",
    "packages/**/*.ts"
  ],
  "ignoreExportsUsedInFile": true
}
